{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": false,
    "target": "ES2020"
  },
  "include": [
    "src/**/*",
    "examples/FireblocksXrpAdapter.service.ts",
    "src/FireblocksXrpSdk.ts",
    "examples/errors",
    "docs"
  ],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
